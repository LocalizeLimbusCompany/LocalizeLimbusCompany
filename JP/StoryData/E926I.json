{
  "dataList": [
    {
      "id": 0,
      "place": "心象鏡ダンジョン",
      "model": "뉴김삿갓",
      "content": "俺が記憶しているよりは少し弱いようだが、\nこっちも烙印を押されている以上、どっこいどっこいだな。"
    },
    {
      "id": 1,
      "model": "이스마엘다침",
      "content": "かなり…うまく戦えているように見えますけど？"
    },
    {
      "id": 2,
      "model": "돈키호테다침",
      "content": "互角…に見えはするのだが…。"
    },
    {
      "id": 3,
      "model": "뉴료슈담배다침",
      "content": "ふぅ…あいつ。死にたくてたまらなさそうに刀を振るっているな。"
    },
    {
      "id": 4,
      "model": "뉴료슈담배다침",
      "content": "自分の実力よりも鈍い刀さばき…。\nこのまま終わりたい、ということか？"
    },
    {
      "id": 5,
      "model": "임경업",
      "content": "どこを見ているんだ！？"
    },
    {
      "id": 6,
      "model": "뉴김삿갓",
      "content": "…！"
    },
    {
      "id": 7,
      "model": "임경업",
      "content": "…<ruby=つば>鍔</ruby>を競り合わせておきながら、受け流そうともせず、力比べか。"
    },
    {
      "id": 8,
      "model": "뉴김삿갓",
      "content": "格好いいじゃないか、こういうの。"
    },
    {
      "id": 9,
      "model": "뉴김삿갓",
      "content": "最後のひとあわせの末、節度使の剣に斬られた\nとある組織の頭目。"
    },
    {
      "id": 10,
      "model": "임경업",
      "content": "…望み通りにしてやろう。"
    },
    {
      "id": 11,
      "model": "뉴김삿갓",
      "content": "…ああ。このまま終わりを―"
    },
    {
      "id": 12,
      "model": "뉴앵두",
      "content": "はぁ…。"
    },
    {
      "id": 14,
      "content": "その瞬間、決着をつけようとするように剣を突き出そうとしていた\nキムサッガッとイム・ギョンオ<size=75%>プ</size>の間に、エンドゥが割って入った。"
    },
    {
      "id": 13,
      "model": "뉴김삿갓",
      "content": "うっ…！エンドゥ？"
    },
    {
      "id": 15,
      "model": "뉴앵두",
      "content": "何がそう恥ずかしくて死のうとなさるのですか、お頭。"
    },
    {
      "id": 16,
      "model": "뉴앵두",
      "content": "これから生きていくことが、それほど恐ろしいのですか？"
    },
    {
      "id": 17,
      "model": "뉴김삿갓",
      "content": "……。"
    },
    {
      "id": 18,
      "model": "뉴김삿갓",
      "content": "…ああ、怖い。任務も、名誉も、親友もすべて失った俺が…\nそれでも天を畏れることも知らず流れ歩いていることが怖い。"
    },
    {
      "id": 19,
      "model": "뉴김삿갓",
      "content": "俺がまともにやり遂げたことなんて、いったい何があるというんだ。\n政争に巻き込まれて信じ仕えた者に捨てられ、\nその後は俺を信じると共に来た親友たちを刀で斬った。"
    },
    {
      "id": 20,
      "model": "뉴김삿갓",
      "content": "流れるままに歩いてみれば、すべての足跡が血の跡だ。\nいっそ盤面が傾いたことを受け入れて―"
    },
    {
      "id": 21,
      "model": "뉴앵두",
      "content": "お頭は力が弱かったがゆえ、任務に失敗なさいました。"
    },
    {
      "id": 22,
      "model": "뉴김삿갓",
      "content": "……。"
    },
    {
      "id": 23,
      "model": "뉴앵두",
      "content": "立場が弱かったがゆえ名誉を失われ、心が弱かったがゆえ親友を斬られました。"
    },
    {
      "id": 24,
      "model": "뉴김삿갓",
      "content": "…エンドゥ。俺を生かそうと割って入ったんじゃなかったのか？\n言葉が痛すぎるんだが。"
    },
    {
      "id": 25,
      "model": "뉴앵두",
      "content": "今度は何が弱くて、信念も命も何もかも捨てようとなさるのですか。"
    },
    {
      "id": 26,
      "model": "뉴앵두",
      "content": "これ以上、弱くなるものがあるとでもいうのですか。"
    },
    {
      "id": 27,
      "model": "뉴앵두",
      "content": "責任を負おうとなさらないでください。\n<ruby=コムゲ>剣契</ruby>がいつから互いに責任を負う集団でありましたか。いつからお頭一人に\nそれほど大きな期待を寄せる集団だったなどと、そのように傲慢に振る舞われるのですか。"
    },
    {
      "id": 28,
      "model": "뉴앵두",
      "content": "<ruby=ドンジュサング>同舟相救</ruby>だの何だの、\nその意味を掲げてほしいと誰かに頼まれでもしましたか？"
    },
    {
      "id": 29,
      "model": "뉴김삿갓",
      "content": "い、痛いってば…。"
    },
    {
      "id": 30,
      "model": "뉴앵두",
      "content": "そのように軽々しくおっしゃるのも、ほどほどになさってください！\n自ら担おうとする責任の重みを軽くしようと、\nわざと軽口を叩いていることを、部下たちが知らなかったとでもお思いですか？"
    },
    {
      "id": 31,
      "model": "뉴앵두",
      "content": "何かを成し遂げろと言った者もおりませんでした。\nお頭がいつも仰っていたではありませぬか。"
    },
    {
      "id": 32,
      "model": "뉴앵두",
      "content": "俺は、自ら振るわれたことのない剣だ。\n誰かに拾われ、使われただけだ。"
    },
    {
      "id": 33,
      "model": "뉴앵두",
      "content": "遺留品に恥や責任もあるのでございましょうか？\n私の知るところではございませぬ。"
    },
    {
      "id": 34,
      "model": "뉴김삿갓",
      "content": "……。"
    },
    {
      "id": 35,
      "model": "뉴앵두",
      "content": "それでも、それほど恥ずかしいのであれば…。"
    },
    {
      "id": 36,
      "model": "뉴앵두",
      "content": "<ruby=サッガッ>編み笠</ruby>でも目深にかぶって、生きてください。"
    },
    {
      "id": 37,
      "model": "뉴앵두",
      "content": "生きて、報いてください。"
    },
    {
      "id": 38,
      "model": "뉴김삿갓",
      "content": "……。"
    },
    {
      "id": 39,
      "model": "뉴김삿갓",
      "content": "…<ruby=ドジョルシジン>刀折矢尽</ruby>。"
    },
    {
      "id": 40,
      "model": "뉴김삿갓",
      "content": "死のうとする心さえお前に負けてしまったのだから、\nこれ以上次の手を探すこともできない。"
    },
    {
      "id": 41,
      "model": "뉴김삿갓",
      "content": "もう…どうしようもないな。"
    },
    {
      "id": 42,
      "model": "뉴앵두",
      "content": "ふぅ…。"
    },
    {
      "id": 43,
      "model": "뉴김삿갓",
      "content": "そうだな。この際、石を収めて剣鬼として生きろという言葉にも、\n一理あったのかもしれない。"
    },
    {
      "id": 44,
      "model": "뉴앵두",
      "content": "お頭…？私はそのようなこと申して…。"
    },
    {
      "id": 45,
      "model": "뉴김삿갓",
      "content": "…興味深いな。その詩はまた、どこで聞いたのか。"
    },
    {
      "id": 46,
      "model": "뉴김삿갓",
      "content": "そう。この<ruby=サッガッ>編み笠</ruby>は、もとより空っぽの舟のようなものだ。\nひっくり返した形が、よく似ているからな。"
    },
    {
      "id": 47,
      "content": "何かの圧に押されるように、\nエンドゥとイム・ギョンオ<size=75%>プ</size>がキムサッガッから弾かれたように遠ざかる。"
    },
    {
      "id": 48,
      "content": "キムサッガッは虚空を見つめ、飄々と笑って何かを言う。"
    },
    {
      "id": 49,
      "content": "その相手が何なのか、私たちは知っている。"
    },
    {
      "id": 50,
      "model": "단테",
      "content": "<声を…。>"
    },
    {
      "id": 51,
      "model": "뉴김삿갓",
      "content": "だが、あなたの一手は悪手だ。斬りたいと思ったにせよ、\nああしてすべて斬り殺させるとは。悪手の中でも、最悪の自滅手だな。"
    },
    {
      "id": 52,
      "model": "뉴김삿갓",
      "content": "ああ。せっかく待ったをかけた数手だ、今度は違うように打とう。"
    },
    {
      "id": 53,
      "model": "뉴김삿갓",
      "content": "気を悪くする必要はない。貴殿の言う通り、\n次の対局はまたどう打つか分からないものだからな。"
    },
    {
      "id": 54,
      "model": "뉴김삿갓",
      "content": "貴殿の口出しも、耳には入れておこう。"
    },
    {
      "id": 55,
      "model": "뉴김삿갓",
      "content": "だが今日の着手は…俺の意志で。"
    },
    {
      "id": 56,
      "model": "히스클리프다침2",
      "content": "…でも、ちょっと違う気がしねぇか。"
    },
    {
      "id": 57,
      "model": "히스클리프다침2",
      "content": "ねじれてるっていうより、あれは…。"
    },
    {
      "id": 58,
      "model": "이상다침",
      "content": "…あるいは、花を咲かすやも知れず。"
    },
    {
      "id": 59,
      "model": "뉴김삿갓",
      "content": "確信は…ない。だが、貴殿も聞いただろう。俺に最後に残った部下の言葉を。"
    },
    {
      "id": 60,
      "model": "뉴김삿갓",
      "content": "俺は本来、拾われて使われていた刀。俺の生に確信などあったはずもない。"
    },
    {
      "id": 61,
      "model": "뉴김삿갓",
      "content": "敗着かもしれないが、俺のこの着手が妙手であることを願うばかり。"
    },
    {
      "id": 62,
      "model": "뉴김삿갓",
      "content": "…声援はありがたく受け取ろう。"
    },
    {
      "id": 63,
      "content": "近づくことのできなかった奇妙な圧力が消えると、\nイム・ギョンオ<size=75%>プ</size>という者がすぐさま剣を構え直す。"
    },
    {
      "id": 64,
      "content": "イム・ギョンオ<size=75%>プ</size>と向き合うキムサッガッの表情は、これまでとは違い、\n晴れやかでありながら、同時に決意に満ちていた。"
    },
    {
      "id": 65,
      "model": "임경업",
      "content": "……。"
    },
    {
      "id": 66,
      "model": "뉴김삿갓안광",
      "content": "…前言を翻すのは、恥ずべき限りだが。"
    },
    {
      "id": 67,
      "model": "뉴김삿갓안광",
      "content": "今度は生きるためにぶつかろう。"
    },
    {
      "id": 68,
      "model": "뉴김삿갓안광",
      "content": "貴殿はやはり、構わぬと言ってくれるだろう？"
    },
    {
      "id": 69,
      "model": "임경업",
      "content": "…いくらでも。"
    },
    {
      "id": 70
    },
    {
      "id": 71,
      "place": -1,
      "model": "뉴김삿갓",
      "content": "天を仰ぐのが怖くてかぶった俺の<ruby=サッガッ>編み笠</ruby>は。"
    },
    {
      "id": 72,
      "model": "뉴김삿갓",
      "content": "あてどない空舟となり、多くの者を乗せ。"
    },
    {
      "id": 73,
      "model": "뉴김삿갓",
      "content": "かぶったまま生涯を共にさすらったのだから。"
    },
    {
      "id": 74,
      "model": "뉴김삿갓",
      "content": "酔えば掛け置き、花見。"
    },
    {
      "id": 75,
      "model": "뉴김삿갓",
      "content": "興が乗れば脱いで手に取り、月見。"
    },
    {
      "id": 76
    },
    {
      "id": 77,
      "model": "뉴김삿갓",
      "content": "そう、この<ruby=サッガッ>編み笠</ruby>をかぶっていれば。"
    },
    {
      "id": 78,
      "model": "뉴김삿갓",
      "content": "雨が降れど風が吹けど、我が身には何の心配もないのだな。"
    },
    {
      "id": 79,
      "model": "임경업",
      "content": "……。"
    },
    {
      "id": 80,
      "model": "임경업",
      "content": "そこの編み笠をかぶった<ruby=ヤンバン>両班</ruby>。風体が怪しい、名を名乗れ。"
    },
    {
      "id": 81,
      "model": "뉴김삿갓",
      "content": "<ruby=コムゲ>剣契</ruby>を率いながら、その責任を果たせず。"
    },
    {
      "id": 82,
      "model": "뉴김삿갓",
      "content": "民草を救おうとしながら、その術を見つけられず。"
    },
    {
      "id": 83,
      "model": "뉴김삿갓",
      "content": "すべてを下ろすことも、背負うこともできなかった者を呼ぶ言葉など、\n他にありもしないゆえ。"
    },
    {
      "id": 84
    },
    {
      "id": 85,
      "model": "뉴김삿갓",
      "content": "俺の名は…キムサッガッ。"
    },
    {
      "id": 86,
      "model": "뉴김삿갓",
      "content": "逆賊、キムサッガッだ。"
    },
